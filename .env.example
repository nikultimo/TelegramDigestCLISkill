# LLM — any OpenAI-compatible endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Telegram delivery (optional — skip if using --dry-run only)
TG_BOT_TOKEN=...       # from @BotFather: https://t.me/BotFather
TG_CHAT_ID=...         # your personal chat ID — message @userinfobot to find it

# Telegram account sync (optional — only needed for `tg-digest sync`)
TG_API_ID=0            # from https://my.telegram.org/apps
TG_API_HASH=...        # from https://my.telegram.org/apps
TG_SESSION=./data/tg_session

# Optional tuning
SCRAPE_LIMIT=20        # max posts to fetch per channel per run
DIGEST_OUTPUT_DIR=./digest_output
DB_PATH=./data/tg_digest.db
